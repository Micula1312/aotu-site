---
import '../styles/constellation.css';
---

<div id="constellation-visualization"></div>
<div id="loading-indicator">Loading media...</div>

<dialog id="lb">
  <button id="lbCloseX" class="lb-close-x" type="button" aria-label="Close"></button>
  <button id="lbPrev" class="lb-nav lb-prev" type="button" aria-label="Previous"></button>
  <button id="lbNext" class="lb-nav lb-next" type="button" aria-label="Next"></button>

  <div class="lb-wrap">
    <div class="lb-media" id="lbMedia"></div>
    <div class="lb-meta">
      <h3 class="lb-title" id="lbTitle"></h3>
      <div class="muted" id="lbInfo"></div>
      <div id="lbTags" style="margin-top:8px"></div>
    </div>
  </div>
</dialog>

<script>
  import * as THREE from 'three';

  // Initialize Three.js scene
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(
    75,
    window.innerWidth / window.innerHeight,
    0.1,
    10000
  );
  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setClearColor(0x000000);
  document.getElementById('constellation-visualization')?.appendChild(renderer.domElement);

  // Raycaster for mouse interaction
  const raycaster = new THREE.Raycaster();
  const mouse = new THREE.Vector2();
  
  // Variables
  const particlesGroup = new THREE.Group();
  const particles: any[] = [];

  const lb = document.getElementById('lb') as HTMLDialogElement | null;
const lbMedia = document.getElementById('lbMedia');
const lbTitle = document.getElementById('lbTitle');
const lbInfo = document.getElementById('lbInfo');
const lbTags = document.getElementById('lbTags');

let CURRENT_INDEX = 0;
let lastFocus: HTMLElement | null = null;

function escapeHtml(s = '') {
  return s.replace(/[&<>"']/g, (m) => ({
    '&':'&amp;',
    '<':'&lt;',
    '>':'&gt;',
    '"':'&quot;',
    "'":'&#39;'
  }[m] || m));
}

async function updateLightbox(item: any) {
  if (!lbMedia) return;

  if (lbTitle) lbTitle.textContent = item.title || 'Untitled';

  const formattedDate = item.date
    ? new Date(item.date).toLocaleDateString('it-IT', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })
    : '';

  if (lbInfo) lbInfo.textContent = formattedDate;

  if (lbTags) {
    const tags = Array.isArray(item.tags)
      ? item.tags.map((tag: string) => `#${escapeHtml(String(tag))}`).join(' ')
      : '';
    lbTags.innerHTML = tags;
  }

  lbMedia.innerHTML = '';

  const img = new Image();
  img.src = item.url;
  img.alt = item.alt || item.title || '';
  lbMedia.appendChild(img);
}

async function openLightbox(item: any, openerEl?: HTMLElement | null) {
  if (!lb || !mediaData.length) return;

  lastFocus = openerEl || (document.activeElement as HTMLElement | null);
  CURRENT_INDEX = mediaData.findIndex((i) => i.id === item.id);
  if (CURRENT_INDEX < 0) CURRENT_INDEX = 0;

  await updateLightbox(mediaData[CURRENT_INDEX]);
  lb.showModal();
}

async function showNext() {
  if (!mediaData.length) return;
  CURRENT_INDEX = (CURRENT_INDEX + 1) % mediaData.length;
  await updateLightbox(mediaData[CURRENT_INDEX]);
}

async function showPrev() {
  if (!mediaData.length) return;
  CURRENT_INDEX = (CURRENT_INDEX - 1 + mediaData.length) % mediaData.length;
  await updateLightbox(mediaData[CURRENT_INDEX]);
}

document.getElementById('lbNext')?.addEventListener('click', showNext);
document.getElementById('lbPrev')?.addEventListener('click', showPrev);
document.getElementById('lbCloseX')?.addEventListener('click', () => lb?.close());

window.addEventListener('keydown', (e) => {
  if (!lb?.open) return;
  if (e.key === 'Escape') lb.close();
  if (e.key === 'ArrowRight') showNext();
  if (e.key === 'ArrowLeft') showPrev();
});

lb?.addEventListener('close', () => {
  lastFocus?.focus?.();
});


  let mediaData: any[] = [];
  let mouseX = 0;
  let mouseY = 0;
  let zoomLevel = 300;
  let hoveredTitle = '';

  // Fetch media from WordPress API
  async function loadMedia() {
    try {
      const loadingIndicator = document.getElementById('loading-indicator');
      if (loadingIndicator) loadingIndicator.textContent = 'Fetching media from WordPress...';

      const response = await fetch('/api/media');
      if (!response.ok) {
        throw new Error(`API error: ${response.status}`);
      }

      mediaData = await response.json();
      console.log(`✅ Loaded ${mediaData.length} media items`);
      
      // AGGIUNGI QUESTO DEBUG:
      console.log('PRIMO MEDIA ITEM:', mediaData[0]);
      console.log('URL:', mediaData[0]?.url);
      console.log('TITLE:', mediaData[0]?.title);

      if (loadingIndicator) loadingIndicator.style.display = 'none';
      createParticles();
    } catch (error) {
      console.error('❌ Failed to load media:', error);
      const loadingIndicator = document.getElementById('loading-indicator');
      if (loadingIndicator) {
        loadingIndicator.textContent = `Error: ${error}`;
        loadingIndicator.style.color = '#ff0000';
      }
    }
  }

  // Create particles from media data
  function createParticles() {
    const count = Math.min(100, Math.max(10, mediaData.length));
    
    for (let i = 0; i < count; i++) {
      const geometry = new THREE.SphereGeometry(6, 8, 8);
      const hue = i / count;
      const material = new THREE.MeshBasicMaterial({ 
        color: new THREE.Color().setHSL(hue, 0.7, 0.6) 
      });
      material.transparent = true;
      material.opacity = 0.85;
      const mesh = new THREE.Mesh(geometry, material);
      
      // Position particles in 3D space
      const x = (Math.random() - 0.5) * 2000;
      const y = (Math.random() - 0.5) * 2000;
      const z = (Math.random() - 0.5) * 2000;
      
      mesh.position.set(x, y, z);
      mesh.userData = {
        ...mediaData[i % mediaData.length],
        originalColor: material.color.getHex(),
        index: i
      };
      
      particlesGroup.add(mesh);
      particles.push(mesh);
    }

    scene.add(particlesGroup);
  }

  // Create starfield background
  function createStarfield() {
    const starGeometry = new THREE.BufferGeometry();
    const starMaterial = new THREE.PointsMaterial({
      color: 0xffffff,
      size: 0.5,
      sizeAttenuation: true,
    });

    const starVertices = [];
    for (let i = 0; i < 5000; i++) {
      starVertices.push(
        (Math.random() - 0.5) * 4000,
        (Math.random() - 0.5) * 4000,
        (Math.random() - 0.5) * 4000
      );
    }

    starGeometry.setAttribute(
      'position',
      new THREE.BufferAttribute(new Float32Array(starVertices), 3)
    );

    const starField = new THREE.Points(starGeometry, starMaterial);
    scene.add(starField);
    return starField;
  }

  const starField = createStarfield();
  camera.position.z = zoomLevel;

  // Mouse move interaction
  document.addEventListener('mousemove', (event) => {
    mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
    mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

    mouseX = (event.clientX / window.innerWidth) - 0.5;
    mouseY = (event.clientY / window.innerHeight) - 0.5;

    raycaster.setFromCamera(mouse, camera);
    const intersects = raycaster.intersectObjects(particles);

    // Reset all particles
    particles.forEach(particle => {
      particle.material.color.setHex(particle.userData.originalColor);
      particle.scale.set(1, 1, 1);
    });

    // Highlight hovered particle
    if (intersects.length > 0) {
      const hovered = intersects[0].object as any;
      hovered.material.color.setHex(0xffff00);
      hovered.scale.set(1.5, 1.5, 1.5);
      hoveredTitle = hovered.userData.title || 'Untitled';
      document.title = hoveredTitle; // Mostra nel title del browser
    } else {
      hoveredTitle = '';
    }
  });

  // Click to show info
document.addEventListener('click', () => {
  raycaster.setFromCamera(mouse, camera);
  const intersects = raycaster.intersectObjects(particles);

  if (intersects.length > 0) {
    const clicked = intersects[0].object as any;
    openLightbox(clicked.userData);
  }
});

function openFromConstellation(data) {

  // ⚠️ questo usa lo stesso sistema dell'archive
  if (!window.STATE || !window.openLightbox) {
    console.warn('Archive not loaded');
    return;
  }

  // trova item corrispondente nell'archive
  const item = window.STATE.items.find(i => i.id === data.id);

  if (!item) {
    console.warn('Item not found in archive');
    return;
  }

  window.openLightbox(item);

}



