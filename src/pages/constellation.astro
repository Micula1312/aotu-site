---
import '../styles/constellation.css';
---

<div id="constellation-visualization"></div>
<div id="loading-indicator">Loading media...</div>

<dialog id="lb">
  <button id="lbCloseX" class="lb-close-x" type="button" aria-label="Close"></button>
  <button id="lbPrev" class="lb-nav lb-prev" type="button" aria-label="Previous"></button>
  <button id="lbNext" class="lb-nav lb-next" type="button" aria-label="Next"></button>

  <div class="lb-wrap">
    <div class="lb-media" id="lbMedia"></div>
    <div class="lb-meta">
      <h3 class="lb-title" id="lbTitle"></h3>
      <div class="muted" id="lbInfo"></div>
      <div id="lbTags" style="margin-top:8px"></div>
    </div>
  </div>
</dialog>

<script>
  import * as THREE from 'three';

  const scene = new THREE.Scene();

  const camera = new THREE.PerspectiveCamera(
    75,
    window.innerWidth / window.innerHeight,
    0.1,
    10000
  );

  const renderer = new THREE.WebGLRenderer({
    antialias: true,
    alpha: true,
    powerPreference: 'high-performance'
  });

  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setClearColor(0x000000, 1);

  const mount = document.getElementById('constellation-visualization');
  mount?.appendChild(renderer.domElement);

  renderer.domElement.style.filter = 'drop-shadow(0 0 24px rgba(255,255,255,0.08))';

  const raycaster = new THREE.Raycaster();
  const mouse = new THREE.Vector2(9999, 9999);

  const particlesGroup = new THREE.Group();
  const particles = [];
  let mediaData = [];

  let mouseX = 0;
  let mouseY = 0;
  let zoomLevel = 300;

  let isDragging = false;
  let dragMoved = false;
  let lastTouchX = 0;
  let lastTouchY = 0;
  let pinchStartDistance = 0;
  let pinchStartZoom = zoomLevel;

  const isTouch = window.matchMedia('(pointer: coarse)').matches;

  const lb = document.getElementById('lb');
  const lbMedia = document.getElementById('lbMedia');
  const lbTitle = document.getElementById('lbTitle');
  const lbInfo = document.getElementById('lbInfo');
  const lbTags = document.getElementById('lbTags');

  let CURRENT_INDEX = 0;
  let lastFocus = null;

  function escapeHtml(s = '') {
    return s.replace(/[&<>"']/g, (m) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;'
    }[m] || m));
  }

  function getTouchDistance(touches) {
    if (touches.length < 2) return 0;
    const dx = touches[0].clientX - touches[1].clientX;
    const dy = touches[0].clientY - touches[1].clientY;
    return Math.sqrt(dx * dx + dy * dy);
  }

  function updatePointerFromClient(clientX, clientY) {
    mouse.x = (clientX / window.innerWidth) * 2 - 1;
    mouse.y = -(clientY / window.innerHeight) * 2 + 1;

    mouseX = (clientX / window.innerWidth) - 0.5;
    mouseY = (clientY / window.innerHeight) - 0.5;
  }

  function pickParticle() {
    raycaster.setFromCamera(mouse, camera);
    const intersects = raycaster.intersectObjects(particles);
    return intersects.length > 0 ? intersects[0].object : null;
  }

  function resetParticles() {
    particles.forEach((particle) => {
      particle.material.color.setHex(particle.userData.originalColor);
      particle.scale.set(1, 1, 1);
    });
  }

  function highlightHovered() {
    resetParticles();
    const hovered = pickParticle();

    if (hovered) {
      hovered.material.color.setHex(0xffffff);
      hovered.scale.set(1.8, 1.8, 1.8);
      document.body.style.cursor = 'pointer';
    } else {
      document.body.style.cursor = 'default';
    }
  }

  async function updateLightbox(item) {
    if (!lbMedia) return;

    if (lbTitle) lbTitle.textContent = item.title || 'Untitled';

    const formattedDate = item.date
      ? new Date(item.date).toLocaleDateString('it-IT', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        })
      : '';

    if (lbInfo) lbInfo.textContent = formattedDate;

    if (lbTags) {
      const tags = Array.isArray(item.tags)
        ? item.tags.map((tag) => `#${escapeHtml(String(tag))}`).join(' ')
        : '';
      lbTags.innerHTML = tags;
    }

    lbMedia.innerHTML = '';

    const img = new Image();
    img.src = item.url;
    img.alt = item.alt || item.title || '';
    lbMedia.appendChild(img);
  }

  async function openLightbox(item, openerEl = null) {
    if (!lb || !mediaData.length) return;

    lastFocus = openerEl || document.activeElement;
    CURRENT_INDEX = mediaData.findIndex((i) => i.id === item.id);
    if (CURRENT_INDEX < 0) CURRENT_INDEX = 0;

    await updateLightbox(mediaData[CURRENT_INDEX]);
    lb.showModal();
  }

  async function showNext() {
    if (!mediaData.length) return;
    CURRENT_INDEX = (CURRENT_INDEX + 1) % mediaData.length;
    await updateLightbox(mediaData[CURRENT_INDEX]);
  }

  async function showPrev() {
    if (!mediaData.length) return;
    CURRENT_INDEX = (CURRENT_INDEX - 1 + mediaData.length) % mediaData.length;
    await updateLightbox(mediaData[CURRENT_INDEX]);
  }

  document.getElementById('lbNext')?.addEventListener('click', showNext);
  document.getElementById('lbPrev')?.addEventListener('click', showPrev);
  document.getElementById('lbCloseX')?.addEventListener('click', () => lb?.close());

  window.addEventListener('keydown', (e) => {
    if (!lb?.open) return;
    if (e.key === 'Escape') lb.close();
    if (e.key === 'ArrowRight') showNext();
    if (e.key === 'ArrowLeft') showPrev();
  });

  lb?.addEventListener('close', () => {
    lastFocus?.focus?.();
  });

  async function loadMedia() {
    try {
      const loadingIndicator = document.getElementById('loading-indicator');
      if (loadingIndicator) {
        loadingIndicator.textContent = 'Fetching media from WordPress...';
      }

      const response = await fetch('/api/media');
      if (!response.ok) {
        throw new Error(`API error: ${response.status}`);
      }

      mediaData = await response.json();

      if (loadingIndicator) loadingIndicator.style.display = 'none';

      createParticles();
    } catch (error) {
      console.error('Failed to load media:', error);
      const loadingIndicator = document.getElementById('loading-indicator');
      if (loadingIndicator) {
        loadingIndicator.textContent = `Error: ${error}`;
        loadingIndicator.style.color = '#ff4d4d';
      }
    }
  }

  function createParticles() {
    const count = isTouch
      ? Math.min(60, Math.max(10, mediaData.length))
      : Math.min(100, Math.max(10, mediaData.length));

    const particleRadius = isTouch ? 4 : 3.2;

    for (let i = 0; i < count; i++) {
      const geometry = new THREE.SphereGeometry(particleRadius, 8, 8);

      const material = new THREE.MeshBasicMaterial({
        color: 0xf2f2f2,
        transparent: true,
        opacity: 0.82
      });

      const mesh = new THREE.Mesh(geometry, material);

      const radius = 300 + Math.random() * 1200;
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);

      const x = radius * Math.sin(phi) * Math.cos(theta);
      const y = radius * Math.sin(phi) * Math.sin(theta) * 0.75;
      const z = radius * Math.cos(phi);

      mesh.position.set(x, y, z);

      mesh.userData = {
        ...mediaData[i % mediaData.length],
        originalColor: material.color.getHex(),
        index: i,
        baseX: x,
        baseY: y,
        baseZ: z
      };

      particlesGroup.add(mesh);
      particles.push(mesh);
    }

    scene.add(particlesGroup);
  }

  function createStarfield() {
    const starGeometry = new THREE.BufferGeometry();
    const starMaterial = new THREE.PointsMaterial({
      color: 0xffffff,
      size: 0.9,
      sizeAttenuation: true,
      transparent: true,
      opacity: 0.9
    });

    const starVertices = [];
    for (let i = 0; i < 5000; i++) {
      starVertices.push(
        (Math.random() - 0.5) * 5000,
        (Math.random() - 0.5) * 5000,
        (Math.random() - 0.5) * 5000
      );
    }

    starGeometry.setAttribute(
      'position',
      new THREE.BufferAttribute(new Float32Array(starVertices), 3)
    );

    const starField = new THREE.Points(starGeometry, starMaterial);
    scene.add(starField);
    return starField;
  }

  const starField = createStarfield();
  camera.position.z = zoomLevel;

  document.addEventListener('mousemove', (event) => {
    updatePointerFromClient(event.clientX, event.clientY);
    highlightHovered();
  });

  document.addEventListener('click', () => {
    if (dragMoved) return;
    const clicked = pickParticle();
    if (clicked) openLightbox(clicked.userData);
  });

  window.addEventListener('wheel', (e) => {
    const speed = 20;
    if (e.deltaY < 0) zoomLevel = Math.max(40, zoomLevel - speed);
    else zoomLevel = Math.min(1200, zoomLevel + speed);
    camera.position.z = zoomLevel;
  });

  const touchTarget = renderer.domElement;

  touchTarget.addEventListener('touchstart', (e) => {
    if (e.touches.length === 1) {
      isDragging = true;
      dragMoved = false;
      lastTouchX = e.touches[0].clientX;
      lastTouchY = e.touches[0].clientY;
      updatePointerFromClient(lastTouchX, lastTouchY);
    }

    if (e.touches.length === 2) {
      isDragging = false;
      pinchStartDistance = getTouchDistance(e.touches);
      pinchStartZoom = zoomLevel;
    }
  }, { passive: true });

  touchTarget.addEventListener('touchmove', (e) => {
    if (e.touches.length === 1 && isDragging) {
      const touch = e.touches[0];
      const dx = touch.clientX - lastTouchX;
      const dy = touch.clientY - lastTouchY;

      if (Math.abs(dx) > 2 || Math.abs(dy) > 2) {
        dragMoved = true;
      }

      mouseX += dx * 0.0015;
      mouseY += dy * 0.0015;

      lastTouchX = touch.clientX;
      lastTouchY = touch.clientY;

      updatePointerFromClient(touch.clientX, touch.clientY);
      highlightHovered();
    }

    if (e.touches.length === 2) {
      const dist = getTouchDistance(e.touches);
      if (pinchStartDistance > 0) {
        const scale = pinchStartDistance / dist;
        zoomLevel = Math.max(40, Math.min(1200, pinchStartZoom * scale));
        camera.position.z = zoomLevel;
      }
    }
  }, { passive: true });

  touchTarget.addEventListener('touchend', (e) => {
    if (e.touches.length === 0) {
      if (!dragMoved) {
        const picked = pickParticle();
        if (picked) openLightbox(picked.userData);
      }
      isDragging = false;
      pinchStartDistance = 0;
    }

    if (e.touches.length === 1) {
      lastTouchX = e.touches[0].clientX;
      lastTouchY = e.touches[0].clientY;
      isDragging = true;
    }
  }, { passive: true });

  function animate() {
    requestAnimationFrame(animate);

    if (particles.length > 0) {
      particlesGroup.rotation.x += (mouseY * 0.5 - particlesGroup.rotation.x) * 0.035;
      particlesGroup.rotation.y += (mouseX * 0.5 - particlesGroup.rotation.y) * 0.035;

      const t = performance.now() * 0.00025;

      particles.forEach((particle, i) => {
        particle.position.x = particle.userData.baseX + Math.sin(t + i * 0.7) * 3.5;
        particle.position.y = particle.userData.baseY + Math.cos(t * 1.2 + i * 0.5) * 3.5;
        particle.position.z = particle.userData.baseZ + Math.sin(t * 0.9 + i * 0.4) * 4.5;
      });
    }

    starField.rotation.x += 0.00004;
    starField.rotation.y += 0.00007;

    renderer.render(scene, camera);
  }

  animate();

  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  loadMedia();
</script>