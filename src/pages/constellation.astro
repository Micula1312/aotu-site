<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

<div id="constellation-visualization" style="width: 100%; height: 100vh;"></div>

<script>
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
  const renderer = new THREE.WebGLRenderer();
  renderer.setSize(window.innerWidth, window.innerHeight);
  document.getElementById('constellation-visualization').appendChild(renderer.domElement);

  const stars = [];
  for (let i = 0; i < 100; i++) {
      let starGeometry = new THREE.SphereGeometry(0.05, 24, 24);
      let starMaterial = new THREE.MeshBasicMaterial({ color: 0xffffff });
      let star = new THREE.Mesh(starGeometry, starMaterial);
      star.position.set(
          (Math.random() - 0.5) * 100,
          (Math.random() - 0.5) * 100,
          (Math.random() - 0.5) * 100
      );
      stars.push(star);
      scene.add(star);
  }

  camera.position.z = 5;

  function animate() {
      requestAnimationFrame(animate);
      stars.forEach(star => {
          star.rotation.x += 0.01;
          star.rotation.y += 0.01;
      });
      renderer.render(scene, camera);
  }
  animate();
</script>

