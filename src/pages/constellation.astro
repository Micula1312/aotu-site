  // Close info panel
  // document.getElementById('close-info')?.addEventListener('click', () => {
  //   document.getElementById('info-panel')?.classList.add('hidden');
  // });

  // Mouse wheel zoom
  window.addEventListener('wheel', (e) => {
    const speed = 20;
    if (e.deltaY < 0) zoomLevel = Math.max(10, zoomLevel - speed);
    else zoomLevel = Math.min(1000, zoomLevel + speed);
    camera.position.z = zoomLevel;
  });

    // Aggiungi glow effect al renderer
  renderer.domElement.style.filter = 'drop-shadow(0 0 30px rgba(0, 255, 0, 0.3))';

  // Aggiungi effetto luminoso alle particelle
  function addParticleGlow() {
    particles.forEach((particle) => {
      const originalScale = particle.scale.x;
      particle.userData.glowScale = originalScale;
    });
  }

  addParticleGlow();

  // Animation loop
  function animate() {
    requestAnimationFrame(animate);
    
    if (particles.length > 0) {
      particlesGroup.rotation.x += (mouseY * 0.5 - particlesGroup.rotation.x) * 0.05;
      particlesGroup.rotation.y += (mouseX * 0.5 - particlesGroup.rotation.y) * 0.05;
    }
    
    starField.rotation.x += 0.00005;
    starField.rotation.y += 0.00008;
    
    renderer.render(scene, camera);
  }

  animate();

  // Handle window resize
  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  // Load media on page load
  loadMedia();

  
</script>